                  "width": "fill_container",
                  "content": "АВАЗЫН ҮЙЛ АЖИЛЛАГААНЫ ХӨТӨЛБӨР 2024-2034",
                  "fontFamily": "Space Grotesk",
                  "fontSize": 17,
                  "fontWeight": "700",
