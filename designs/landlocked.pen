                },
                {
                  "type": "text",
                  "id": "wqGwh",
                  "name": "Body",
                  "fill": "#6B7280",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Худалдаа, худалдааг хөнгөвчлөх, бүс нутгийн интеграцчлал нь ДГХБО-ын эдийн засгийн өсөлт, олон улсын зах зээлд нэвтрэх, далайд гарцгүй байдлаас үүдэх өртгийг бууруулахад чиглэнэ. Гаалийн процессыг хялбаршуулах, стандартыг нийцүүлэх, хилийн ойролцоох худалдааны дэд бүтцийг сайжруулах, бүс нутгийн худалдааны хэлэлцээрүүдэд идэвхтэй оролцох нь чухал.",
                  "lineHeight": 1.7,
