                    },
                    {
                      "type": "text",
                      "id": "T3e6u",
                      "name": "Body",
                      "fill": "#374151",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Томилогдохоос өмнө тэрээр 2014 оноос эхлэн ITTLLDC-ийн түр үе шатанд судалгааны координатороор ажиллаж, 2019 онд Үйл ажиллагааны захирлаар дэвшсэн. Түүний хичээл зүтгэлийн ачаар далайд гарцгүй хөгжиж буй орнуудад зориулсан судалгааны төв байгуулах санаа бодитой болж, 2017 оны аравдугаар сарын 6-нд холбогдох олон талт хэлэлцээр хүчин төсөлд орсон. Энэ нь Монгол Улсад төвтэй анхны олон улсын засгийн газар хоорондын байгууллага, мөн НҮБ-ын далайд гарцгүй хөгжиж буй орнуудын бүлгийн анхны засгийн газар хоорондын байгууллага хууль ёсоор байгуулагдсаныг баталгаажуулсан.",
                      "lineHeight": 1.7,
                      "fontFamily": "Space Grotesk",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    }
                  ]
                },
