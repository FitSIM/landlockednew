            {
              "type": "text",
              "id": "ELIww",
              "name": "P2",
              "fill": "#374151",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "Алматы хотод өрнүүлсэн дараа далайд гарцгүй орнуудын худалдааны асуудлаар илүү гүнзгий судалгаа, олон талт хэлэлцүүлэг хийх шаардлага тулгарсан. Энэ хүрээнд олон улсын судалгааны төв байгуулах санаа улам бодитой болж, 2006 онд Монгол Улсын Ерөнхийлөгчийн Хавана хотод болсон далайд гарцгүй орнуудын төрийн тэргүүн нарын уулзалтад нийтлэг сэргэлтийн ордны, далайд гарцгүй орнууд бүтцийн хөгжлийн дэд шинжилгээний талаар бодлогын баримт бичгийг танилцуулсан. Монгол Улсын Ерөнхийлөгчийн 2006 оны мэндчилгээндээ санаачлагыг чангартаж дэм шинжилгээ нь далайд гарцгүй орнуудын нийтлэг бэрхшээлийг тодорхойлох, шийдвэрлэх арга замыг тодорхойлох, бодлогын ажилд нэг мөртөөр туслах зорилгыг харуулжээ. Энэ үеэр олон улсын судалгааны төв нь далайд гарцгүй орнуудын бодлого боловсруулагчдад зориулсан нотолгоонд суурилсан мэдээлэл, шинжилгээний үйлчилгээ үзүүлэх үндэс суурь болох нь тодорхой болсон.",
              "lineHeight": 1.8,
              "fontFamily": "$font-heading",
              "fontSize": 14,
              "fontWeight": "normal"
            },
