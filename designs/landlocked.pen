                {
                  "type": "text",
                  "id": "v6yGs",
                  "name": "Subtitle",
                  "fill": "#6B7280",
                  "textGrowth": "fixed-width",
                  "width": 800,
                  "content": "Тайлан, судалгаа, хуралдааны болон эрх зүйн баримт бичгүүдийг сэдвээр нь ангилан хялбархан хайх, татах боломжтой. Эдгээр материал нь далайд гарцгүй хөгжиж буй орнуудын хөгжлийн бодлого, худалдаа, тээвэр, дэд бүтцийн төлөв байдал, олон улсын хамтын ажиллагааны үр дүнг тодорхойлон, мэдлэгт суурилсан шийдвэр гаргахад тусална.",
                  "lineHeight": 1.7,
                  "fontFamily": "Space Grotesk",
